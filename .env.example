# OpenSky Network API Credentials
VITE_REACT_OSKY_CLIENT_ID=your_client_id_here
VITE_REACT_OSKY_CLIENT_SECRET=your_client_secret_here

# AirportDB API Token
VITE_AIRPORTDB_TOKEN=your_airportdb_token_here

# Proxy Server Port (optional, defaults to 3001)
PROXY_PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/flight_tracker

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
